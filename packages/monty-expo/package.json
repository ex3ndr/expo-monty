{
  "name": "monty-expo",
  "version": "0.1.0",
  "description": "Nitro Modules bridge for Monty on iOS and Android",
  "license": "MIT",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "source": "src/index.ts",
  "files": [
    "android",
    "ios",
    "cpp",
    "nitrogen",
    "src",
    "build",
    "nitro.json",
    "MontyExpo.podspec",
    "post-script.js",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "codegen": "nitrogen --logLevel=\"debug\" && node post-script.js",
    "build:rust": "bash ./scripts/build-rust-all.sh",
    "build:rust:ios": "bash ./scripts/build-rust-ios.sh",
    "build:rust:android": "bash ./scripts/build-rust-android.sh",
    "build:native": "yarn build:rust && yarn codegen && yarn build",
    "clean": "rm -rf build",
    "prepare": "yarn build"
  },
  "keywords": [
    "nitro",
    "react-native",
    "monty",
    "python",
    "module"
  ],
  "devDependencies": {
    "nitrogen": "0.35.0",
    "react": "19.2.0",
    "react-native": "0.82.1",
    "react-native-nitro-modules": "0.35.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  }
}
